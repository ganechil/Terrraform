
#config MS Azure Providers
provider "azurerm" {
  //configure terraform app registeration in azure 
  subscription_id = "098ae160-379b-4c33-93c3-c749b638d510"
  client_id       = "f4625e31-02dc-4cf5-bea1-bd0c1ae40a96"
  client_secret   = " terraform app registered secret key"
  tenant_id       = "ce4c2cfb-13f3-4d1f-abc5-de58f4d808a4"
  features {}
}

#create a resource group
resource "azurerm_resource_group" "db-rg" {
  location = "west us"
  name     = "db-rg"
}


//Azure CLI commands to delete
#az group delete --name adb-rg --yes --no-wait	

//delete particular resource
#az resource delete --resource-group "db-rg" --name "dbstrg" --resource-type "Microsoft.Compute/virtualMachines"


//create a storage account
resource "azurerm_storage_account" "dbstrggc" {
  name                     = "dbstrggc"
  resource_group_name      = azurerm_resource_group.db-rg.name
  location                 = azurerm_resource_group.db-rg.location
  account_tier             = "Standard"
  account_replication_type = "LRS"
}

//create azure sql server
resource "azurerm_mssql_server" "azsqlpaasetldbsrvr" {
  name                         = "azsqlpaasetldbsrvr"
  resource_group_name          = azurerm_resource_group.db-rg.name
  location                     = "West US"
  version                      = "12.0"
  administrator_login          = "etladmin"
  administrator_login_password = azurerm_key_vault_secret.kvsecretgc.value
  depends_on                   = [azurerm_resource_group.db-rg]

  tags = {
    environment = "staging"
  }
}

//create azure sql database
resource "azurerm_mssql_database" "etldb" {
  name        = "etldb"
  server_id   = azurerm_mssql_server.azsqlpaasetldbsrvr.id
  collation   = "SQL_Latin1_General_CP1_CI_AS"
  sku_name    = "S0"
  max_size_gb = 2
  depends_on  = [azurerm_mssql_server.azsqlpaasetldbsrvr, azurerm_resource_group.db-rg]
}

//create firewall rule for azure sql server
resource "azurerm_mssql_firewall_rule" "SQLgcFirewallRule1" {
  name             = "SQLgcFirewallRule1"
  server_id        = azurerm_mssql_server.azsqlpaasetldbsrvr.id
  start_ip_address = "0.0.0.0"
  end_ip_address   = "255.255.255.255"
}

//https://www.youtube.com/watch?v=gMFLh8QFRZg
//Key vault
data "azurerm_client_config" "current" {}

resource "azurerm_key_vault" "kvgc" {
  name                = "kvsql-gc"
  location            = azurerm_resource_group.db-rg.location
  resource_group_name = azurerm_resource_group.db-rg.name
  tenant_id           = data.azurerm_client_config.current.tenant_id
  sku_name            = "standard"

  access_policy {
    tenant_id          = data.azurerm_client_config.current.tenant_id
    object_id          = data.azurerm_client_config.current.object_id
    secret_permissions = ["Get", "List", "Set"]

  }
}

resource "azurerm_key_vault_secret" "kvsecretgc" {
  name         = "sql-password"
  value        = "@Sdf123456"
  key_vault_id = azurerm_key_vault.kvgc.id
  depends_on   = [azurerm_key_vault.kvgc]
}
